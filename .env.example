# Copy to .env for local runs:  cp .env.example .env  (then fill in)
# In GitHub, set these as repository secrets instead (Settings → Secrets → Actions).

GEMINI_API_KEY=your-google-ai-studio-key
RESEND_API_KEY=your-resend-api-key
# Optional fallback brain used when Gemini is exhausted (free-tier 503/429):
OPEN_ROUTER_API_KEY=your-openrouter-key

# Free way to email ANY recipient (incl. @kore.com) with no domain/IT: send via
# your own Gmail. Set BOTH and the agent uses Gmail SMTP instead of Resend.
# GMAIL_APP_PASSWORD is a 16-char Google "App Password" (needs 2-Step Verification
# on the account) — NOT your normal password. Create at:
#   Google Account → Security → 2-Step Verification → App passwords
GMAIL_ADDRESS=youraddress@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop

# Optional overrides:
# GEMINI_MODEL=gemini-2.5-pro
# DIGEST_DRY_RUN=1
